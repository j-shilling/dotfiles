{
  "mcpServers": {
    "terraform": {
      "tools": [
        "*"
      ],
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "hashicorp/terraform-mcp-server:0.5.1"
      ],
      "source": "user",
      "sourcePath": "/home/jake/.copilot/mcp-config.json"
    },
    "aws-mcp": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata",
        "AWS_REGION=us-east-1"
      ],
      "source": "user",
      "sourcePath": "/home/jake/.copilot/mcp-config.json"
    },
    "Linear": {
      "tools": [
        "*"
      ],
      "type": "http",
      "url": "https://mcp.linear.app/mcp",
      "headers": {},
      "source": "user",
      "sourcePath": "/home/jake/.copilot/mcp-config.json"
    },
    "notion": {
      "tools": [
        "*"
      ],
      "type": "http",
      "url": "https://mcp.notion.com/mcp",
      "headers": {},
      "source": "user",
      "sourcePath": "/home/jake/.copilot/mcp-config.json"
    },
    "playwright": {
      "type": "local",
      "command": "npx",
      "tools": [
        "*"
      ],
      "args": [
        "@playwright/mcp@latest",
        "--browser=firefox"
      ]
    }
  }
}
