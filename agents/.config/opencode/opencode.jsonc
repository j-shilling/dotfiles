{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "formatter": true,

  "skills": {
    "dirs": [
      "~/.config/agents/skills/",
      ".opencode/skills/"
    ]
  },

  "model": "openrouter/openrouter/auto",
  "small_model": "openrouter/openrouter/auto",

  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    },
    "ollama": {
      "name": "Ollama",
      "api": "openai",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  },

  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest", "--browser=firefox"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    // filesystem MCP requires $HOME as a final command arg — not portable in shared config
    "grafana": {
      "type": "remote",
      "url": "https://mcp.grafana.com/mcp",
      "headers": {
        "X-Grafana-URL": "https://pathable.grafana.net"
      }
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    }
  },

  "tools": {
    "notion_*": false,
    "grafana_*": false
  },

  "agent": {
    "code": {
      "mode": "subagent",
      "model": "openrouter/pareto-code",
      "description": "Focused code generation via pareto-optimized model. Use for code-heavy subtasks."
    },
    "grafana": {
      "grafana_*": true,
      "read": true,
      "write": false,
      "bash": false,
      "edit": false
    },
    "notion-context": {
      "tools": {
        "notion_*": true,
        "read": true,
        "write": true,
        "bash": false,
        "edit": false
      }
    }
  }
}
